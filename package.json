{
  "name": "hover-translate-replace",
  "displayName": "Hover Translate Replace",
  "description": "为悬浮提示补充翻译结果，并提供常用文本替换能力。",
  "version": "0.0.2",
  "publisher": "loveyu",
  "license": "MIT",
  "keywords": [
    "hover",
    "translate",
    "translation",
    "translator",
    "comment",
    "rename",
    "pascalcase"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/loveyu233/hover-translate-replace.git"
  },
  "bugs": {
    "url": "https://github.com/loveyu233/hover-translate-replace/issues"
  },
  "homepage": "https://github.com/loveyu233/hover-translate-replace#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:go",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:java",
    "onLanguage:python",
    "onLanguage:rust"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hoverTranslateReplace.clearCache",
        "title": "清空翻译缓存"
      },
      {
        "command": "hoverTranslateReplace.toggleOriginal",
        "title": "切换原文显示"
      },
      {
        "command": "hoverTranslateReplace.replaceSelectionBidirectional",
        "title": "中英互译替换"
      },
      {
        "command": "hoverTranslateReplace.replaceSelectionAsPascalCase",
        "title": "替换为大驼峰"
      }
    ],
    "keybindings": [
      {
        "command": "hoverTranslateReplace.replaceSelectionBidirectional",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "hoverTranslateReplace.replaceSelectionAsPascalCase",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "hoverTranslateReplace.replaceSelectionBidirectional",
          "when": "editorHasSelection",
          "group": "1_modification@99"
        },
        {
          "command": "hoverTranslateReplace.replaceSelectionAsPascalCase",
          "when": "editorHasSelection",
          "group": "1_modification@100"
        }
      ]
    },
    "configuration": {
      "title": "Hover Translate Replace",
      "properties": {
        "hoverTranslateReplace.enabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用悬浮翻译增强。"
        },
        "hoverTranslateReplace.provider": {
          "type": "string",
          "enum": [
            "google-free",
            "openai-compatible",
            "tencent-cloud"
          ],
          "default": "google-free",
          "description": "翻译服务提供方。"
        },
        "hoverTranslateReplace.targetLanguage": {
          "type": "string",
          "default": "zh-CN",
          "description": "目标语言，例如 zh-CN、en、ja。"
        },
        "hoverTranslateReplace.includeOriginal": {
          "type": "boolean",
          "default": false,
          "description": "是否在译文下方附带原文。"
        },
        "hoverTranslateReplace.skipIfSourceMatchesTarget": {
          "type": "boolean",
          "default": true,
          "description": "当注释看起来已经是目标语言时，直接不显示额外译文。"
        },
        "hoverTranslateReplace.maxChars": {
          "type": "number",
          "default": 2500,
          "minimum": 200,
          "description": "单次翻译的最大字符数，超出后会截断。"
        },
        "hoverTranslateReplace.timeoutMs": {
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "description": "翻译请求超时时间，单位毫秒。"
        },
        "hoverTranslateReplace.googleApiUrl": {
          "type": "string",
          "default": "https://translate.googleapis.com/translate_a/single",
          "description": "google-free 模式使用的翻译接口地址。"
        },
        "hoverTranslateReplace.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI 兼容接口的基础地址。"
        },
        "hoverTranslateReplace.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI 兼容接口的 API Key。"
        },
        "hoverTranslateReplace.openaiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "OpenAI 兼容接口使用的模型名。"
        },
        "hoverTranslateReplace.tencentSecretId": {
          "type": "string",
          "default": "",
          "description": "腾讯云 API 的 SecretId。"
        },
        "hoverTranslateReplace.tencentSecretKey": {
          "type": "string",
          "default": "",
          "description": "腾讯云 API 的 SecretKey。"
        },
        "hoverTranslateReplace.tencentRegion": {
          "type": "string",
          "default": "ap-beijing",
          "description": "腾讯云机器翻译接口请求地域，例如 ap-beijing。"
        },
        "hoverTranslateReplace.tencentProjectId": {
          "type": "number",
          "default": 0,
          "description": "腾讯云机器翻译项目 ID，默认 0。"
        },
        "hoverTranslateReplace.tencentSourceLanguage": {
          "type": "string",
          "default": "auto",
          "description": "腾讯云机器翻译源语言，默认 auto。"
        },
        "hoverTranslateReplace.tencentEndpoint": {
          "type": "string",
          "default": "https://tmt.tencentcloudapi.com",
          "description": "腾讯云机器翻译接口地址。"
        },
        "hoverTranslateReplace.title": {
          "type": "string",
          "default": "译文",
          "description": "悬浮框中译文区域的标题。设为空可不显示标题。"
        }
      }
    }
  }
}
